{
  "mcpServers": {
    "miro": {
      "serverUrl": "https://mcp.miro.com/"
    },
    "gemini-image": {
      "command": "node",
      "args": [
        "./.opencode/mcp/gemini-image-server.mjs"
      ],
      "env": {
        "GEMINI_API_KEY": "${GEMINI_API_KEY}",
        "GEMINI_IMAGE_MODEL": "${GEMINI_IMAGE_MODEL}",
        "GEMINI_IMAGE_OUTPUT_DIR": "./.opencode/generated-images"
      }
    },
    "web-fetcher": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ]
    }
  }
}
